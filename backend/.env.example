# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=AI Study Assistant
APP_ENV=development
DEBUG=True
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000

# ============================================
# DATABASE - MONGODB (REQUIRED)
# ============================================
MONGODB_URL=mongodb://localhost:27017/studyai
# Or MongoDB Atlas Cloud: 
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/studyai?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION - JWT (REQUIRED)
# ============================================
SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# GOOGLE OAUTH (OPTIONAL - COMMENTED OUT)
# ============================================
# Uncomment and configure if you want Google login
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ============================================
# LLM API - GOOGLE GEMINI (REQUIRED)
# ============================================
# Get free API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-gemini-api-key

# ============================================
# LLM APIs (OPTIONAL - COMMENTED OUT)
# ============================================
# Uncomment if you want to use OpenAI or Anthropic
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# VECTOR DATABASE - PINECONE (REQUIRED)
# ============================================
# Sign up at: https://www.pinecone.io/
# For Python 3.13, use pinecone v5 (not pinecone-client)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=studyai-embeddings

# ============================================
# REDIS CACHE (OPTIONAL - COMMENTED OUT)
# ============================================
# Uncomment if you want to enable Redis caching
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf
MAX_FILES_PER_SUBJECT=10
UPLOAD_DIR=./uploads

# ============================================
# EMBEDDINGS CONFIGURATION
# ============================================
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================
# LLM SETTINGS
# ============================================
DEFAULT_LLM=gemini-2.0-flash-exp
DEFAULT_TEMPERATURE=0.7
MAX_TOKENS=4096

# ============================================
# EMAIL CONFIGURATION (FOR PASSWORD RESET)
# ============================================
# GMAIL SETUP (Recommended):
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate an "App Password" for "Mail"
# 5. Use that 16-character password below (not your Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@studyai.com
EMAIL_FROM_NAME=AI Study Assistant

# OTHER EMAIL PROVIDERS:
# 
# Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
#
# Yahoo Mail:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=your-email@yahoo.com
#
# Custom SMTP:
# SMTP_HOST=your-smtp-server.com
# SMTP_PORT=587 (or 465 for SSL)
# SMTP_USER=your-username
# SMTP_PASSWORD=your-password

# ============================================
# CORS SETTINGS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# CELERY (OPTIONAL - COMMENTED OUT)
# ============================================
# Uncomment if you want background task processing
# Requires Redis to be installed and running
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# MONITORING (OPTIONAL - COMMENTED OUT)
# ============================================
# Uncomment if you want error tracking with Sentry
# SENTRY_DSN=your-sentry-dsn-url
